# D Company ERP — Production environment.
# Copy this file to .env on the production VM and replace EVERY value
# marked CHANGE_ME. The deploy script (infra/scripts/install-on-vm.sh)
# will generate strong random secrets for you the first time it runs.

# ----- runtime -----
ENV=prod
LOG_LEVEL=INFO
LOG_FORMAT=json
API_PREFIX=/api/v1
EXPOSE_DOCS=false      # never expose /docs publicly in prod

# ----- the domain you bought -----
# Used by Caddy for HTTPS, CORS, and link-building in receipts.
DOMAIN=CHANGE_ME.com

# ----- database -----
# Strong password generated by the install script; rotate annually.
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
DATABASE_URL=postgresql+psycopg://erp:CHANGE_ME_strong_random_password@postgres:5432/erp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ----- redis -----
REDIS_URL=redis://redis:6379/0

# ----- JWT (auth) -----
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_48_char_base64_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# ----- CORS -----
# Lock to your real domain. Add Capacitor origins when shipping the iOS/iPadOS app.
# (DuckDNS subdomains do NOT support a www variant — keep just the bare one.)
CORS_ORIGINS=["https://CHANGE_ME.com","https://localhost","capacitor://localhost","ionic://localhost"]

# ----- object storage (OCR uploads) -----
# Leave the MinIO defaults if you're running it on the VM.
# If you switch to S3/R2 later, update these values.
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=erp-uploads
S3_ACCESS_KEY=erp
S3_SECRET_KEY=CHANGE_ME_minio_password

# ----- localization -----
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# ----- seed data (deploy-time) -----
# Owner login created by the seed script. CHANGE THE PASSWORD IMMEDIATELY
# after your first login.
SEED_OWNER_EMAIL=owner@CHANGE_ME.com
SEED_OWNER_PASSWORD=CHANGE_ME_strong_owner_password
SEED_COMPANY_NAME=D Company
SEED_COMPANY_GSTIN=32ABCDE1234F1Z5     # update with your real GSTIN
SEED_BRANCH_NAME=Main Branch
SEED_BRANCH_CODE=MN
SEED_BRANCH_STATE_CODE=32              # 32 = Kerala
SEED_BRANCH_FSSAI=12345678901234       # update with your real FSSAI licence
