# D Company ERP — frontend build config.
# Copy to `.env` for local dev (the Vite proxy handles /api otherwise).
# For packaged builds (Tauri / Capacitor / CI), pass this in via the build environment.

# Absolute API URL used by packaged native apps. Leave blank for browser/dev.
VITE_API_URL=https://api.dcompany.cloud/api/v1

# Surfaced in the UI "About" screen. CI fills this from the git tag.
VITE_APP_VERSION=1.0.0

# Optional: branch identifier shown in the UI.
VITE_RELEASE_CHANNEL=stable
