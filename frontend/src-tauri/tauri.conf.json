{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "D Company ERP",
  "version": "1.0.0",
  "identifier": "cloud.dcompany.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "D Company ERP",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.dcompany.cloud https://*.dcompany.cloud; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "category": "Business",
    "copyright": "© 2026 D Company",
    "shortDescription": "D Company café + gaming-lounge ERP",
    "longDescription": "Production-grade ERP / POS / inventory / gaming-lounge management for D Company.",
    "publisher": "D Company",
    "homepage": "https://dcompany.cloud",
    "targets": ["dmg", "app", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null,
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": { "language": "en-US" },
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  },
  "plugins": {}
}
