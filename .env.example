# D Company ERP — copy to .env and edit. Never commit a real .env.

ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=json
API_PREFIX=/api/v1
EXPOSE_DOCS=true

# Database
DATABASE_URL=postgresql+psycopg://erp:erp@localhost:5432/erp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — in production use RS256 + secrets manager
JWT_SECRET=please-rotate-me-please-rotate-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Object storage
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_UPLOADS=erp-uploads
S3_ACCESS_KEY=erp
S3_SECRET_KEY=erp_change_me

# OCR
OCR_PROVIDER=tesseract
OCR_CONFIDENCE_THRESHOLD=0.75

# Localization
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# CORS
CORS_ORIGINS=["http://localhost:5173"]
