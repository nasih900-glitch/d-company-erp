SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# D Company ERP automated owner reports.
# Times are UTC. 02:30 UTC = 08:00 Asia/Kolkata.
30 2 * * * root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period daily >> /var/log/dcompany-erp-alerts.log 2>&1
35 2 * * 1 root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period weekly >> /var/log/dcompany-erp-alerts.log 2>&1
40 2 1 * * root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period monthly >> /var/log/dcompany-erp-alerts.log 2>&1
45 2 1 1,4,7,10 * root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period quarterly >> /var/log/dcompany-erp-alerts.log 2>&1
50 2 1 4,10 * root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period half_yearly >> /var/log/dcompany-erp-alerts.log 2>&1
55 2 1 4 * root cd /opt/d-company-erp && docker compose -f docker-compose.prod.yml --env-file .env exec -T backend python -m app.workers.pnl_alerts --period yearly >> /var/log/dcompany-erp-alerts.log 2>&1
